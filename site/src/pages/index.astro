---
const watchExamples = [
  {
    label: "sync",
    file: "site/src/pages/index.astro",
    description: "Page edits are copied into the running container.",
  },
  {
    label: "sync+restart",
    file: "site/astro.config.mjs",
    description: "Config edits are copied, then the dev server restarts.",
  },
  {
    label: "rebuild",
    file: "site/package.json",
    description: "Dependency edits rebuild the image.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>docker compose watch example</title>
  </head>
  <body>
    <main>
      <p class="eyebrow">Astro sample site</p>
      <h1>docker compose watch example</h1>
      <p class="lead">
        Edit the files below while <code>docker compose watch</code> is running
        to see sync, restart, and rebuild behavior.
      </p>
      <section aria-label="Watch examples">
        {
          watchExamples.map((example) => (
            <article>
              <strong>{example.label}</strong>
              <code>{example.file}</code>
              <p>{example.description}</p>
            </article>
          ))
        }
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color: #1f2933;
    background: #f7f9fb;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  body {
    margin: 0;
  }

  main {
    width: min(960px, calc(100% - 40px));
    margin: 0 auto;
    padding: 88px 0;
  }

  .eyebrow {
    margin: 0 0 12px;
    color: #0f766e;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1 {
    max-width: 720px;
    margin: 0;
    color: #111827;
    font-size: clamp(2.5rem, 8vw, 5.5rem);
    line-height: 0.95;
  }

  .lead {
    max-width: 680px;
    margin: 28px 0 48px;
    color: #4b5563;
    font-size: 1.25rem;
    line-height: 1.6;
  }

  code {
    padding: 0.15rem 0.35rem;
    border-radius: 4px;
    background: #e6edf3;
    color: #0f172a;
    font-size: 0.95em;
  }

  section {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  article {
    min-height: 152px;
    padding: 20px;
    border: 1px solid #d9e2ec;
    border-radius: 8px;
    background: #ffffff;
  }

  strong {
    display: block;
    margin-bottom: 18px;
    color: #0f766e;
    font-size: 1rem;
  }

  article code {
    display: inline-block;
    max-width: 100%;
    overflow-wrap: anywhere;
  }

  article p {
    margin: 16px 0 0;
    color: #52606d;
    line-height: 1.5;
  }

  @media (max-width: 760px) {
    main {
      width: min(100% - 28px, 520px);
      padding: 56px 0;
    }

    section {
      grid-template-columns: 1fr;
    }
  }
</style>
